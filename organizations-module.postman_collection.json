            "body": {
              "mode": "raw",
              "raw": "{\n  \"organizationName\": \"Stanford Institute\",\n  \"type\": \"institution\",\n  \"emailDomain\": \"stanford.edu\",\n  \"location\": \"California, USA\",\n  \"description\": \"Research and learning organization\",\n  \"primaryContactName\": \"Dr. Sarah Cooper\",\n  \"adminEmail\": \"admin@stanford.edu\",\n  \"phoneCode\": \"+1\",\n  \"mobileNo\": \"5551234567\",\n  \"roleTitle\": \"Director of Education\",\n  \"accessPlan\": \"premium\",\n  \"billingCycle\": \"monthly\",\n  \"subscriptionStatus\": \"active\",\n  \"status\": \"active\",\n  \"students\": [\n    {\n      \"name\": \"Priya Sharma\",\n      \"email\": \"priya@stanford.edu\",\n      \"password\": \"Password123!\",\n      \"mobileNo\": \"+919900000001\"\n    },\n    {\n      \"name\": \"Rahul Kumar\",\n      \"email\": \"rahul@stanford.edu\",\n      \"password\": \"Password123!\",\n      \"mobileNo\": \"+919900000002\"\n    }\n  ],\n  \"accessPermissions\": [\n    { \"code\": \"webinars\", \"enabled\": true, \"limit\": 10, \"usedCount\": 0, \"accessExpiry\": null },\n    { \"code\": \"cohorts\", \"enabled\": true, \"limit\": 5, \"usedCount\": 0, \"accessExpiry\": null },\n    { \"code\": \"mentorship\", \"enabled\": false, \"limit\": null, \"usedCount\": 0, \"accessExpiry\": null },\n    { \"code\": \"certification_courses\", \"enabled\": true, \"limit\": null, \"usedCount\": 0, \"accessExpiry\": null },\n    { \"code\": \"assignments\", \"enabled\": true, \"limit\": 20, \"usedCount\": 0, \"accessExpiry\": null }\n  ],\n  \"invoice\": {\n    \"invoiceId\": \"INV-001\",\n    \"amount\": 24000,\n    \"currency\": \"INR\",\n    \"invoiceDate\": \"2026-01-01\",\n    \"paymentDate\": \"2026-01-31\",\n    \"paymentMethod\": \"Bank Transfer\",\n    \"billingCycle\": \"monthly\",\n    \"planType\": \"Seat-based\",\n    \"paymentStatus\": \"paid\",\n    \"nextBillingDate\": \"2026-02-01\"\n  },\n  \"payment\": {\n    \"amount\": 24000,\n    \"currency\": \"INR\",\n    \"paymentMethod\": \"Bank Transfer\",\n    \"paymentDate\": \"2026-01-31\",\n    \"paymentStatus\": \"paid\",\n    \"transactionRef\": \"TXN-10001\",\n    \"notes\": \"Initial payment\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/organizations",
              "host": ["{{baseUrl}}"],
              "path": ["api", "organizations"]
