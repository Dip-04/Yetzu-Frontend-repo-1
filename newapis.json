    {
      "name": "Coupon Management",
      "description": "Admin coupon CRUD flow.",
      "item": [
        {
          "name": "List Coupons",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/coupons?page=1&limit=10",
              "host": ["{{baseUrl}}"],
