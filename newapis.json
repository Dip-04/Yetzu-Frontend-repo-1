    },
    {
      "name": "Reschedule Flow",
      "description": "Student request, educator session request, and educator review.",
      "item": [
        {
          "name": "Student Request Reschedule",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{studentToken}}" },
              { "key": "x-user-id", "value": "{{studentUserId}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"courseId\": \"{{courseId}}\",\n  \"reason\": \"I have a university exam on that day.\",\n  \"proposedDate\": \"2026-05-25T10:00:00.000Z\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/student/course/reschedule-request",
              "host": ["{{baseUrl}}"],
              "path": ["api", "student", "course", "reschedule-request"]
            }
          }
        },
        {
          "name": "Educator Request Session Reschedule",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{educatorToken}}" },
              { "key": "x-user-id", "value": "{{educatorUserId}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionId\": \"{{sessionId}}\",\n  \"proposedDate\": \"2026-05-25\",\n  \"proposedTime\": \"10:30\",\n  \"reason\": \"Need to move the session due to instructor availability.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/educator/session/reschedule-request",
              "host": ["{{baseUrl}}"],
              "path": ["api", "educator", "session", "reschedule-request"]
            }
          }
        },
        {
          "name": "Educator Review Reschedule",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{educatorToken}}" },
              { "key": "x-user-id", "value": "{{educatorUserId}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"courseId\": \"{{courseId}}\",\n  \"requestId\": \"<requestId>\",\n  \"action\": \"approved\",\n  \"educatorRemark\": \"Approved, shifting to next week.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/educator/reschedule-action",
              "host": ["{{baseUrl}}"],
              "path": ["api", "educator", "reschedule-action"]
            }
          }
        }
      ]
    },
    {
      "name": "Student Certificates",
      "description": "Fetch the merged certificates generated from completed certificate-enabled sessions.",
      "item": [
        {
          "name": "List Student Certificates",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{studentToken}}" },
              { "key": "x-user-id", "value": "{{studentUserId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/student/certificates",
              "host": ["{{baseUrl}}"],
              "path": ["api", "student", "certificates"]
            }
          }
        }
      ]
    }
  ]
}
