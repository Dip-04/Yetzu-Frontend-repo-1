              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Launch Offer\",\n  \"code\": \"LAUNCH20\",\n  \"discountType\": \"percentage\",\n  \"discountValue\": 20,\n  \"maxUses\": 100,\n  \"status\": \"active\"\n}"
            },
